rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    /// Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    /// Check if user owns this document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /// Check if user's email is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    /// Check if update only modifies allowed fields
    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    /// Check if update only modifies rating-related fields (for rating system)
    function isRatingUpdate() {
      return isSignedIn() && onlyChanges(['rating', 'updatedAt']);
    }

    /// Check if update only modifies blocked users field
    function isBlockUpdate() {
      return isSignedIn() && onlyChanges(['blockedUsers', 'updatedAt']);
    }

    /// Get user document
    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    /// Check if current user is blocked by target user
    function isBlockedBy(targetUserId) {
      let targetUser = getUser(targetUserId);
      return targetUser.blockedUsers != null &&
             request.auth.uid in targetUser.blockedUsers;
    }

    /// Check if current user has blocked target user
    function hasBlocked(targetUserId) {
      let currentUser = getUser(request.auth.uid);
      return currentUser.blockedUsers != null &&
             targetUserId in currentUser.blockedUsers;
    }

    /// Validate string field length
    function validStringLength(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    /// Validate that a timestamp is recent (within last 5 minutes)
    function isRecentTimestamp(ts) {
      return ts is timestamp &&
             ts >= request.time - duration.value(5, 'm') &&
             ts <= request.time + duration.value(1, 'm');
    }

    // ========================================================================
    // USERS COLLECTION
    // ========================================================================
    match /users/{userId} {
      // Anyone signed in can read user profiles (for discovery)
      // But blocked users cannot read each other's profiles
      allow read: if isSignedIn();

      // Users can only create their own profile with valid data
      allow create: if isOwner(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.email == request.auth.token.email &&
        validStringLength(request.resource.data.displayName, 2, 50);

      // Users can update their own profile
      // OR any signed-in user can update rating fields (for rating system)
      // OR any signed-in user can update their own blockedUsers
      allow update: if isOwner(userId) || isRatingUpdate();

      // No direct delete allowed - use Cloud Functions for account deletion
      allow delete: if false;
    }

    // ========================================================================
    // CATEGORIES COLLECTION (Read-Only for clients)
    // ========================================================================
    match /categories/{categoryId} {
      // Anyone can read categories (even unauthenticated for app preview)
      allow read: if true;

      // Only admin can write (via Firebase Console or Cloud Functions)
      allow write: if false;
    }

    // ========================================================================
    // SWAPS COLLECTION
    // ========================================================================
    match /swaps/{swapId} {
      // Users can only read swaps they're part of
      allow read: if isSignedIn() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );

      // Users can create swap requests if:
      // - They are the requester
      // - They haven't blocked the provider and vice versa
      // - Valid data is provided
      allow create: if isSignedIn() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.requesterId != request.resource.data.providerId &&
        request.resource.data.status == 'pending' &&
        !isBlockedBy(request.resource.data.providerId) &&
        !hasBlocked(request.resource.data.providerId) &&
        validStringLength(request.resource.data.requesterOffers, 1, 100) &&
        validStringLength(request.resource.data.requesterWants, 1, 100);

      // Users can update swaps they're part of
      // Validate status transitions
      allow update: if isSignedIn() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      ) && (
        // Allow status changes
        (resource.data.status == 'pending' &&
          request.resource.data.status in ['accepted', 'rejected', 'cancelled']) ||
        (resource.data.status == 'accepted' &&
          request.resource.data.status in ['scheduled', 'cancelled']) ||
        (resource.data.status == 'scheduled' &&
          request.resource.data.status in ['inProgress', 'cancelled']) ||
        (resource.data.status == 'inProgress' &&
          request.resource.data.status in ['completed', 'cancelled']) ||
        // Allow session and rating updates without status change
        onlyChanges(['session', 'updatedAt']) ||
        onlyChanges(['ratings', 'updatedAt']) ||
        onlyChanges(['session', 'ratings', 'updatedAt'])
      );

      // No direct delete
      allow delete: if false;
    }

    // ========================================================================
    // CHATS COLLECTION
    // ========================================================================
    match /chats/{chatId} {
      // Users can only read chats they're part of
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      // Users can create chats with valid data
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;

      // Users can update chats they're part of
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      // No direct delete
      allow delete: if false;

      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Users can read messages in chats they're part of
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Users can create messages if they're in the chat and are the sender
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          validStringLength(request.resource.data.content, 1, 2000);

        // Users can update messages (mark as read)
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          onlyChanges(['readBy']);

        // No delete
        allow delete: if false;
      }
    }

    // ========================================================================
    // TRANSACTIONS COLLECTION
    // ========================================================================
    match /transactions/{userId}/history/{transactionId} {
      // Users can only read their own transactions
      allow read: if isOwner(userId);

      // Users can create their own transaction records
      allow create: if isOwner(userId) &&
        request.resource.data.userId == userId;

      // No update or delete - transactions are immutable
      allow update, delete: if false;
    }

    // ========================================================================
    // REPORTS COLLECTION
    // ========================================================================
    match /reports/{reportId} {
      // Users can read their own reports
      allow read: if isSignedIn() &&
        resource.data.reporterId == request.auth.uid;

      // Users can create reports with valid data
      allow create: if isSignedIn() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.reporterId != request.resource.data.reportedUserId &&
        request.resource.data.status == 'pending' &&
        validStringLength(request.resource.data.description, 10, 1000) &&
        request.resource.data.reason in ['inappropriate', 'spam', 'no_show', 'fraud', 'other'];

      // No update or delete - reports are immutable once submitted
      allow update, delete: if false;
    }

    // ========================================================================
    // NOTIFICATIONS COLLECTION
    // ========================================================================
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Signed in users can create notifications (for other users)
      // This allows the app to send notifications to other users
      allow create: if isSignedIn() &&
        request.resource.data.userId != null &&
        validStringLength(request.resource.data.title, 1, 100) &&
        validStringLength(request.resource.data.body, 1, 500);

      // Users can only update their own notifications (mark as read)
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        onlyChanges(['isRead']);

      // Users can only delete their own notifications
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ========================================================================
    // CATCH-ALL: Deny access to any other collections
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}