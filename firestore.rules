rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // HELPER FUNCTIONS
    // ========================================================================

    /// Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    /// Check if user owns this document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /// Check if user's email is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    /// Check if user is a participant in swap/chat
    function isParticipant(data) {
      return request.auth.uid in data.participants ||
             request.auth.uid == data.requesterId ||
             request.auth.uid == data.providerId;
    }

    /// Validate that a field hasn't changed
    function fieldUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ========================================================================
    // USERS COLLECTION
    // ========================================================================
    match /users/{userId} {
      // Anyone signed in can read user profiles (for discovery)
      allow read: if isSignedIn();

      // Users can only create their own profile with correct initial values
      allow create: if isOwner(userId) &&
        request.resource.data.uid == userId &&
        request.resource.data.creditBalance == 1.0 &&  // Welcome bonus
        request.resource.data.swapsCompleted == 0 &&
        request.resource.data.hoursExchanged == 0 &&
        request.resource.data.rating.average == 0 &&
        request.resource.data.rating.count == 0 &&
        request.resource.data.status == 'active';

      // Users can update their own profile
      // But CANNOT directly modify: creditBalance, rating, swapsCompleted, hoursExchanged
      allow update: if isOwner(userId) &&
        fieldUnchanged('creditBalance') &&
        fieldUnchanged('rating') &&
        fieldUnchanged('swapsCompleted') &&
        fieldUnchanged('hoursExchanged') &&
        fieldUnchanged('uid') &&
        fieldUnchanged('createdAt');

      // No direct delete allowed
      allow delete: if false;
    }

    // ========================================================================
    // CATEGORIES COLLECTION (Read-Only for clients)
    // ========================================================================
    match /categories/{categoryId} {
      // Anyone can read categories (needed before auth for skill selection)
      allow read: if true;

      // Only admin can write (via Firebase Console)
      allow write: if false;
    }

    // ========================================================================
    // SWAPS COLLECTION
    // ========================================================================
    match /swaps/{swapId} {
      // Participants can read their swaps
      allow read: if isSignedIn() && isParticipant(resource.data);

      // Verified users can create swap requests
      allow create: if isSignedIn() &&
        isEmailVerified() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.createdAt == request.time;

      // Participants can update swaps (status changes, ratings, session details)
      allow update: if isSignedIn() &&
        isParticipant(resource.data) &&
        fieldUnchanged('requesterId') &&
        fieldUnchanged('providerId') &&
        fieldUnchanged('createdAt');

      // No direct delete
      allow delete: if false;
    }

    // ========================================================================
    // CHATS COLLECTION
    // ========================================================================
    match /chats/{chatId} {
      // Participants can read chat
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      // Participants can create chat (usually when swap is accepted)
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.participants;

      // Participants can update chat (last message, unread count)
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ======================================================================
      // MESSAGES SUBCOLLECTION
      // ======================================================================
      match /messages/{messageId} {
        // Participants can read messages
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // Participants can create messages (only as themselves)
        allow create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.createdAt == request.time;

        // Messages can be updated (for read receipts)
        allow update: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow delete: if false;
      }
    }

    // ========================================================================
    // TRANSACTIONS COLLECTION (User's transaction history)
    // ========================================================================
    match /transactions/{userId}/history/{transactionId} {
      // Users can only read their own transactions
      allow read: if isOwner(userId);

      // Transactions are created during swap completion
      // This is a simplified rule - in production, you'd want more validation
      allow create: if isSignedIn() && isOwner(userId);

      // No updates or deletes
      allow update: if false;
      allow delete: if false;
    }

    // ========================================================================
    // REPORTS COLLECTION
    // ========================================================================
    match /reports/{reportId} {
      // Users can read their own reports
      allow read: if isSignedIn() &&
        resource.data.reporterId == request.auth.uid;

      // Users can create reports (only as themselves)
      allow create: if isSignedIn() &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.createdAt == request.time;

      // No updates or deletes from client
      allow update: if false;
      allow delete: if false;
    }

    // ========================================================================
    // CATCH-ALL: Deny everything else
    // ========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}